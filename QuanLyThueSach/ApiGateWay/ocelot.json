{
  "Routes": [
    {
      "DownstreamPathTemplate": "/api/{everything}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 44352
        }
      ],
      "UpstreamPathTemplate": "/gateway/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE" ],
      "SwaggerKey": "qlts"
    }
  ],
  "SwaggerEndPoints": [
    {
      "Key": "qlts",
      "Config": [
        {
          "Name": "QuanLyThueSach API",
          "Version": "v1",
          "Url": "https://localhost:44352/swagger/v1/swagger.json"
        }
      ]
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "https://localhost:7053"
  }
}